# --------------------------------------------------- #
# Database (PostgreSQL via Docker)                    #
# Format: postgres://user:password@host:port/database #
# --------------------------------------------------- #
DATABASE_URL="postgres://admin:password@localhost:5432/application_db"

# ------------------------------------------------ #
# Authentication (Better Auth)                     #
# Generate a secret using: openssl rand -base64 32 #
# ------------------------------------------------ #
BETTER_AUTH_SECRET="generated_better_auth_secret_here"
BETTER_AUTH_URL="http://localhost:5173" # The URL of your React Router Web App

# ------------------------------------------- #
# Background Jobs & Queues (Redis via Docker) #
# ------------------------------------------- #
REDIS_URL="redis://localhost:6379"

# --------------------------------- #
# Object Storage (MinIO via Docker) #
# --------------------------------- #
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ROOT_USER="admin"
MINIO_ROOT_PASSWORD="password123"
MINIO_USE_SSL="false"

# ----------------------- #
# Email Provider (Resend) #
# ----------------------- #
RESEND_API_KEY="re_123456789"